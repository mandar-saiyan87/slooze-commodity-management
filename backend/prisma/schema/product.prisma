model Product {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  stock        Int      @default(0)
  imgUrl       String?
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
}
